{
	"schemaVersion": 1,
	"id": "immersiveminimaps",
	"version": "${version}",
	"name": "Immersive Minimaps",
	"description": "A minimalist, client-side minimap that integrates Hoofprint into the player's UI, allowing it to only be visible as long as the player has a map.",
	"authors": [
		"cassiancc"
	],
	"contact": {
		"homepage": "https://modrinth.com/project/immersive-minimaps",
		"sources": "https://github.com/cassiancc/Immersive-Minimaps",
		"issues": "https://github.com/cassiancc/Immersive-Minimaps/issues"
	},
	"license": "LGPL-3.0-or-later",
	"icon": "assets/immersiveminimaps/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"cc.cassian.immersiveminimaps.ModClient"
		]
	},
	"mixins": [
		"immersiveminimaps.mixins.json"
	],
	"depends": {
		"fabricloader": "*",
		"minecraft": "${minecraft}",
		"fabric-api": "*",
		"surveyor": "*",
		"hoofprint": "*"
	}
}